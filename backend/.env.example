DATABASE_URL="postgresql://musallih:musallih@localhost:5433/musallih"
REDIS_URL="redis://localhost:6379"
PORT=3000
NODE_ENV=development
POSTGRES_PASSWORD=musallih
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN_SECONDS=900
JOBS_ENABLED=true
API_RATE_LIMIT_MAX=200
API_RATE_LIMIT_WINDOW="1 minute"

# CORS (comma-separated origins; default: localhost:3000, localhost:5173)
# CORS_ORIGINS=https://app.example.com,https://staging.example.com

# Firebase Admin - required for auth token exchange (POST /v1/auth/token)
# Option A: Service account file path
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/firebase-service-account.json
# Option B: Inline credentials (preferred for containers)
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
