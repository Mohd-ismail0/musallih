{
  "openapi": "3.1.0",
  "info": {
    "title": "Musallih API",
    "description": "Open Islamic Civic Infrastructure Platform",
    "version": "1.0"
  },
  "servers": [{ "url": "/v1", "description": "API v1" }],
  "tags": [
    { "name": "health", "description": "Health checks" },
    { "name": "public", "description": "Public open APIs (no auth)" },
    { "name": "identity", "description": "Identity and profile (OAuth)" },
    { "name": "organization", "description": "Organizations (OAuth)" },
    { "name": "prayer", "description": "Prayer times (public)" },
    { "name": "calendar", "description": "Hijri calendar (public)" },
    { "name": "discovery", "description": "Discovery and maps (public)" },
    { "name": "services", "description": "Services and activities (OAuth)" },
    { "name": "requests", "description": "Service requests and cases (OAuth)" },
    { "name": "ads", "description": "Ads campaigns and revenue (OAuth)" }
  ],
  "paths": {
    "/health": {
      "get": {
        "tags": ["health"],
        "summary": "Health check",
        "operationId": "healthCheck",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string" },
                    "timestamp": { "type": "string", "format": "date-time" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/health/live": {
      "get": {
        "tags": ["health"],
        "summary": "Liveness probe",
        "operationId": "healthLive",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": { "status": { "type": "string", "enum": ["alive"] } }
                }
              }
            }
          }
        }
      }
    },
    "/health/ready": {
      "get": {
        "tags": ["health"],
        "summary": "Readiness probe",
        "operationId": "healthReady",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": { "status": { "type": "string", "enum": ["ready"] } }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "required": ["code", "message"],
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" },
          "details": { "type": "object" }
        }
      },
      "PaginationMeta": {
        "type": "object",
        "properties": {
          "total": { "type": "integer" },
          "page": { "type": "integer" },
          "limit": { "type": "integer" },
          "totalPages": { "type": "integer" }
        }
      }
    }
  }
}
